# ── Server Environment Variables ──────────────────────────

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Publishable / anon key — used for GoTrue (signUp, signIn, getUser JWT).
SUPABASE_ANON_KEY=your_supabase_publishable_or_anon_key
# Service role — server-only; use for PostgREST writes if RLS blocks the anon key.
# Leave unset in dev only if your policies allow the anon key for server routes.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Server port
PORT=5000

# Node environment
NODE_ENV=development

# Stripe
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_MONTHLY=price_XXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_ANNUAL=price_XXXXXXXXXXXXXXXXXXXX

# Frontend URL (for CORS in production)
CLIENT_URL=http://localhost:5173
